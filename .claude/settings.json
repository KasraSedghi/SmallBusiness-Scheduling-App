{
  "permissions": {
    "allow": [
      "npm run dev",
      "npm run build",
      "git status",
      "git diff",
      "git log -n 5"
    ]
  },
  "mcp": {
    "servers": {
      "supabase": {
        "command": "npx",
        "args": [
          "-y",
          "@anthropic-ai/supabase-mcp"
        ],
        "env": {
          "SUPABASE_URL": "https://your-project-id.supabase.co",
          "SUPABASE_API_KEY": "your-supabase-service-role-key-here"
        }
      },
      "postgres": {
        "command": "npx",
        "args": [
          "-y",
          "@modelcontextprotocol/server-postgres",
          "--connection-string",
          "postgresql://postgres:YOUR_PASSWORD@db.your-project-id.supabase.co:5432/postgres"
        ]
      }
    }
  },
  "enableAllProjectMcpServers": true
}